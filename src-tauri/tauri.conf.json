{
  "build": {
    "beforeBuildCommand": "node build.js",
    "beforeDevCommand": "node build.js",
    "devPath": "../dist",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Wireline",
    "version": "1.11.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.wireline.app",
      "longDescription": "Wireline — a WindTerm-style terminal manager with a built-in AI Operator.",
      "resources": [],
      "shortDescription": "Terminal manager with an AI Operator",
      "targets": ["nsis"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 820,
        "resizable": true,
        "title": "Wireline",
        "width": 1280,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  }
}
